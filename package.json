{
  "name": "rehua-api",
  "version": "0.0.1",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/BozhanL/rehua-api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BozhanL/rehua-api.git"
  },
  "bugs": {
    "url": "https://github.com/BozhanL/rehua-api/issues"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24",
    "npm": "^11.11"
  },
  "scripts": {
    "build": "nest build",
    "type": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --max-warnings 0 --fix .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm run test -- --watch",
    "test:cov": "npm run test -- --coverage",
    "test:debug": "node --experimental-vm-modules --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run test -- --config ./test/jest.config.ts",
    "check-all:par": "concurrently --kill-others-on-fail npm:type npm:lint npm:test:cov npm:test:e2e npm:format",
    "check-all": "npm run check-all:par -- -m 1",
    "fix-all": "concurrently -m 1 --kill-others-on-fail npm:lint:fix npm:format:fix",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/cz-commitlint": "20.5.1",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@types/supertest": "7.2.0",
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jiti": "2.6.1",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@commitlint/cz-commitlint"
    }
  }
}
